# AWS CDK Malware Analysis Sandbox Environment Variables
# Copy this file to .env and fill in your values

# AWS Account and Region (optional, CDK uses defaults if not set)
# CDK_DEFAULT_ACCOUNT=123456789012
# CDK_DEFAULT_REGION=us-east-1

# Security Configuration
ALLOWED_IP=192.168.1.1/32  # Your public IP for bastion SSH access
EC2_KEY_PAIR=your-key-pair-name  # Your EC2 key pair name

# AWS Region for AMI (update if deploying to different region)
AMI_REGION=us-east-1

# Optional: Custom AMI ID (leave empty to use default Ubuntu 22.04)
# CUSTOM_AMI_ID=ami-12345678

# Optional: Instance types
# BASTION_INSTANCE_TYPE=t3.micro
# ANALYSIS_INSTANCE_TYPE=t3.medium

# Optional: S3 bucket name prefix (leave empty for auto-generated)
# BUCKET_NAME_PREFIX=malware-analysis

# Optional: Enable additional monitoring (true/false)
# ENABLE_VPC_FLOW_LOGS=true
# ENABLE_CLOUDWATCH_ALARMS=false